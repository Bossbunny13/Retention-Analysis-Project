{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-retention-analysis"
		},
		"LS_ADLS_Retention_Lake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_Retention_Lake'"
		},
		"AzureKeyVault_Retention_Analysis_bunny_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-retention-analysis.vault.azure.net/"
		},
		"AzureSqlDatabase1_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "server-retentsion-analysis.database.windows.net"
		},
		"AzureSqlDatabase1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "db_retention_analysis_bunny"
		},
		"AzureSqlDatabase1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "bunny"
		},
		"LS_ADLS_Retention_Lake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://storage01retention.dfs.core.windows.net/"
		},
		"LS_RestWebiner_platform_bunny_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://jsonplaceholder.typicode.com"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-retention-analysis_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADLS_Retention_Lake_accountKey": {
						"value": "[parameters('LS_ADLS_Retention_Lake_accountKey')]"
					},
					"AzureKeyVault_Retention_Analysis_bunny_properties_typeProperties_baseUrl": {
						"value": "[parameters('AzureKeyVault_Retention_Analysis_bunny_properties_typeProperties_baseUrl')]"
					},
					"LS_ADLS_Retention_Lake_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_Retention_Lake_properties_typeProperties_url')]"
					},
					"LS_RestWebiner_platform_bunny_properties_typeProperties_url": {
						"value": "[parameters('LS_RestWebiner_platform_bunny_properties_typeProperties_url')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_server')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_database')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}